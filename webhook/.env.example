# webhook/.env.example — copy to .env and fill in real values
# chmod 600 .env  — never commit .env to git

# ── Server ────────────────────────────────────────────────────────
NODE_PORT=443
USE_SSL=true
# Set USE_SSL=false for local testing (skips TLS cert loading)

# ── TLS (Let's Encrypt — production only) ─────────────────────────
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem

# ── Meta / WhatsApp Cloud API ─────────────────────────────────────
WA_PHONE_NUMBER_ID=1234567890123456
WA_ACCESS_TOKEN=EAAxxxxxxxxxx
WA_VERIFY_TOKEN=your-random-uuid
WA_APP_SECRET=your-app-secret

# ── Access control ────────────────────────────────────────────────
# E.164 numbers without +, comma-separated
ALLOWED_NUMBERS=33612345678,33698765432

# ── FastAPI internal address ──────────────────────────────────────
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000

# ── Logging ───────────────────────────────────────────────────────
LOG_FILE=logs/webhook.log
LOG_LEVEL=INFO
