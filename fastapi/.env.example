# .env.example — copy to .env and fill in real values
# chmod 600 .env  — never commit .env to git

# ── IPX800 V4 (accessed via local LAN IP) ─────────────────────────
IPX800_HOST=192.168.1.100
IPX800_PORT=80
IPX800_APIKEY=your-ipx800-apikey-here
IPX800_TIMEOUT=5.0
IPX800_RETRY=3

# ── Relay Mapping ─────────────────────────────────────────────────
RELAY_LIGHT=1
RELAY_CURTAIN_UP=2
RELAY_CURTAIN_DOWN=3

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/fastapi.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7
